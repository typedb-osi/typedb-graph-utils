{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./graph-utils",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["graph-utils/**/*"],
  "exclude": ["node_modules", "dist"]
}
